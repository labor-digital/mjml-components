{
  "compilerOptions": {
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "incremental": false,
    "inlineSources": true,
    "inlineSourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": [
      "node"
    ],
    "lib": ["ES6", "DOM"],
    "target": "ES6",
    "module": "CommonJS",
    "declarationMap": true,
//    "sourceMap": true,
    "outDir": "./lib",
    "rootDir": "./src",
//    "allowSyntheticDefaultImports": true,
//    "useDefineForClassFields": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib", "previews"]
}
